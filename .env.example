# ============================================================
# NYC Rat Risk Intelligence — environment variable template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ------------------------------------------------------------------
# NYC Open Data (Socrata)
# https://data.cityofnewyork.us/profile/app_tokens
# ------------------------------------------------------------------
NYC_SOCRATA_APP_TOKEN=

# ------------------------------------------------------------------
# U.S. Census Bureau API
# https://api.census.gov/data/key_signup.html
# Used for ACS 5-year Table B19013 (median household income)
# ------------------------------------------------------------------
CENSUS_API_KEY=

# ------------------------------------------------------------------
# Weather (optional — meteostat works unauthenticated for most calls)
# ------------------------------------------------------------------
NOAA_API_TOKEN=

# ------------------------------------------------------------------
# Embeddings + rerank + LLMs
# ------------------------------------------------------------------
VOYAGE_API_KEY=
COHERE_API_KEY=             # Optional; enables Cohere Rerank 3.5 ablation
ANTHROPIC_API_KEY=
OPENAI_API_KEY=             # For eval judges only

# ------------------------------------------------------------------
# Database (Supabase Free)
# DATABASE_URL       = pooled connection (PgBouncer) — use for queries
# DIRECT_DATABASE_URL = direct connection — use for Alembic migrations
# ------------------------------------------------------------------
DATABASE_URL=
DIRECT_DATABASE_URL=

# ------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OTEL_SERVICE_NAME=rat-api
OBS_JSONL_PATH=/var/log/rat-api/traces.jsonl
SENTRY_DSN=

# ------------------------------------------------------------------
# Geospatial / Planetary Computer (mostly anonymous; key speeds up)
# ------------------------------------------------------------------
PLANETARY_COMPUTER_KEY=

# ------------------------------------------------------------------
# Frontend (public — safe to expose in browser bundles)
# ------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_SENTRY_DSN=
